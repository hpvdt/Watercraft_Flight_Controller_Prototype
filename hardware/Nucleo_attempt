/* ══════════════════════════════════════════════════════════════════════════════
 * HELPER: Microsecond Delay
 * TIM3 is configured as a free-running counter at 1 MHz (1 tick = 1 µs).
 * We read the counter, add the desired delay, and spin until we reach it.
 * Using __HAL_TIM_GET_COUNTER() reads the CNT register directly - very fast.
 * ══════════════════════════════════════════════════════════════════════════════ */
void delay_us(uint32_t us) {
    // __HAL_TIM_SET_COUNTER sets TIM3's counter register to 0
    __HAL_TIM_SET_COUNTER(&htim3, 0);
    // Spin until the counter reaches our target
    // This is a "busy-wait" loop - the CPU does nothing else while waiting
    while (__HAL_TIM_GET_COUNTER(&htim3) < us);
}

/* ══════════════════════════════════════════════════════════════════════════════
 * HELPER: Write Servo Angle (0–180°)
 * Converts degrees → microseconds → timer compare register value.
 *
 * HAL_TIM_PWM is a hardware timer channel generating a fixed-frequency square
 * wave. The "Compare" register (CCR) sets how many ticks the pulse stays HIGH.
 * At 1 MHz timer clock: CCR value = pulse width in microseconds.
 *
 * __HAL_TIM_SET_COMPARE(&htim2, SERVO_CHANNEL, pulse_us)
 *   → writes directly to TIM2->CCR3 (the compare register for channel 3)
 * ══════════════════════════════════════════════════════════════════════════════ */
void servo_write(int angle) {
    // Clamp angle to valid range
    if (angle < SERVO_MIN) angle = SERVO_MIN;
    if (angle > SERVO_MAX) angle = SERVO_MAX;

    // Map 0–180° to 1000–2000 µs (standard servo pulse range)
    // This is the same math as Arduino's Servo.write() internally:
    //   pulse = MIN + (angle / 180.0) * (MAX - MIN)
    uint32_t pulse_us = SERVO_US_MIN + (uint32_t)((angle / 180.0) * (SERVO_US_MAX - SERVO_US_MIN));

    // Write the compare value to the PWM channel
    // This takes effect on the next PWM cycle (within 20ms)
    __HAL_TIM_SET_COMPARE(&htim2, SERVO_CHANNEL, pulse_us);
}

/* ══════════════════════════════════════════════════════════════════════════════
 * INTERRUPT CALLBACK: Input Capture
 * This function is called AUTOMATICALLY by the HAL whenever TIM1 captures
 * an edge on its input pin (PA8 / Echo).
 *
 * "Callback" = a function you write that the HAL calls for you.
 * It OVERRIDES a weak (empty) function defined inside the HAL library.
 * The keyword "weak" in C means "use this definition unless a stronger one exists."
 *
 * How Input Capture works:
 *   - TIM1 runs continuously, counting up at a set frequency
 *   - When the Echo pin changes state, TIM1 snapshots its counter into CCR1
 *   - The HAL calls this callback and tells us which channel fired
 *   - We alternate between detecting rising and falling edges by flipping
 *     the polarity setting after each capture
 * ══════════════════════════════════════════════════════════════════════════════ */
void HAL_TIM_IC_CaptureCallback(TIM_HandleTypeDef *htim) {

    // Guard: only handle TIM1, Channel 1 (our Echo pin)
    if (htim->Instance != TIM1 || htim->Channel != HAL_TIM_ACTIVE_CHANNEL_1)
        return;

    // Read the captured counter value
    // HAL_TIM_ReadCapturedValue() reads TIM1->CCR1
    uint32_t captured = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);

    if (!ic_done) {  // Only process if we're waiting for a new pulse
        if (ic_rising == 0) {
            // First capture = rising edge
            ic_rising = captured;

            // Flip polarity to detect the FALLING edge next time
            // TIM_INPUTCHANNELPOLARITY_FALLING tells the timer to capture
            // on the next HIGH→LOW transition
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1,
                                          TIM_INPUTCHANNELPOLARITY_FALLING);
        } else {
            // Second capture = falling edge
            ic_falling = captured;
            ic_done = 1;  // Signal to main loop that a pulse is ready

            // Reset polarity back to RISING for the next trigger cycle
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1,
                                          TIM_INPUTCHANNELPOLARITY_RISING);
        }
    }
}

/* ══════════════════════════════════════════════════════════════════════════════
 * SENSOR: Read Height via HC-SR04
 * Same logic as Arduino, but using HAL GPIO and our delay_us() instead of
 * digitalWrite() and delayMicroseconds().
 *
 * HAL_GPIO_WritePin(PORT, PIN, STATE)
 *   → sets a specific GPIO pin HIGH (GPIO_PIN_SET) or LOW (GPIO_PIN_RESET)
 *   → equivalent to Arduino's digitalWrite()
 * ══════════════════════════════════════════════════════════════════════════════ */
double read_height(void) {
    // Reset input capture state
    ic_rising = 0;
    ic_falling = 0;
    ic_done = 0;

    // Send 10µs trigger pulse (same as Arduino version)
    HAL_GPIO_WritePin(PIN_TRIG_PORT, PIN_TRIG_PIN, GPIO_PIN_RESET);
    delay_us(2);
    HAL_GPIO_WritePin(PIN_TRIG_PORT, PIN_TRIG_PIN, GPIO_PIN_SET);
    delay_us(10);
    HAL_GPIO_WritePin(PIN_TRIG_PORT, PIN_TRIG_PIN, GPIO_PIN_RESET);

    // Wait for the interrupt callback to signal a complete pulse
    // Timeout after 30ms (ball at 5m away = 29ms round trip - worst case)
    uint32_t timeout = HAL_GetTick() + 30;  // HAL_GetTick() = millis()
    while (!ic_done && HAL_GetTick() < timeout);

    if (!ic_done) return -1.0;  // Timeout = no echo received

    // Calculate pulse width in microseconds
    // Handle timer overflow (counter wraps around at its ARR period)
    // TIM1 ARR must be set to 0xFFFF or similar in CubeMX for this to work
    uint32_t pulse_ticks;
    if (ic_falling >= ic_rising) {
        pulse_ticks = ic_falling - ic_rising;
    } else {
        // Timer overflowed between rising and falling edge
        // Assuming TIM1 ARR = 0xFFFF (16-bit timer)
        pulse_ticks = (0xFFFF - ic_rising) + ic_falling;
    }

    // Convert ticks → cm (same formula as Arduino)
    // Assumes TIM1 is configured with 1MHz clock (1 tick = 1µs)
    // Speed of sound = 0.0343 cm/µs, divide by 2 for round trip
    return (pulse_ticks * 0.0343) / 2.0;
}




/* ══════════════════════════════════════════════════════════════════════════════
 * PID: Identical logic to Arduino version
 * ══════════════════════════════════════════════════════════════════════════════ */

void initialize_PID(PIDController *p, double Kp, double Ki, double Kd) {
    p->Kp = Kp; p->Ki = Ki; p->Kd = Kd;
    p->integral = 0; p->prev_error = 0;
}

double compute_PID(PIDController *p, double target, double current, double dt) {
    double error = target - current;
    double P = p->Kp * error;
    p->integral += error * dt;
    if (p->integral >  50.0) p->integral =  50.0;
    if (p->integral < -50.0) p->integral = -50.0;
    double I = p->Ki * p->integral;
    double D = p->Kd * (error - p->prev_error) / dt;
    p->prev_error = error;
    return P + I + D;
}


/* ══════════════════════════════════════════════════════════════════════════════
 * SETUP — replaces Arduino's setup()
 * In CubeMX-generated code, all peripheral Init() calls are placed BEFORE
 * you reach USER CODE sections. Add your code in the USER CODE BEGIN blocks.
 * ══════════════════════════════════════════════════════════════════════════════ */
void app_init(void) {
    // Start PWM on TIM2 Channel 3 (Servo)
    // This begins toggling the PA3/PB10 pin at 50Hz
    HAL_TIM_PWM_Start(&htim2, SERVO_CHANNEL);

    // Start Input Capture with Interrupts on TIM1 Channel 1 (Echo)
    // "WithIT" means "with Interrupt" - the callback fires on each edge
    HAL_TIM_IC_Start_IT(&htim1, TIM_CHANNEL_1);

    // Start TIM3 as a free-running counter (for delay_us)
    HAL_TIM_Base_Start(&htim3);

    // Center the servo
    servo_write(SERVO_DEFAULT);

    // Initialize PID
    initialize_PID(&pid, 10.0, 10.0, 0.0);

    // Wait 1 second for servo to reach center and sensor to stabilize
    HAL_Delay(1000);  // HAL_Delay() = Arduino's delay() in milliseconds

    last_pid_time = HAL_GetTick();
}



/* ══════════════════════════════════════════════════════════════════════════════
 * LOOP — replaces Arduino's loop()
 * Call this repeatedly from inside main()'s while(1) loop.
 * ══════════════════════════════════════════════════════════════════════════════ */
void app_loop(void) {
    uint32_t current_time = HAL_GetTick();

    if (current_time - last_pid_time >= SAMPLE_TIME) {
        double dt = (current_time - last_pid_time) / 1000.0;
        last_pid_time = current_time;

        double current_height = read_height();
        if (current_height < 0 || current_height > 100) return;

        double correction = compute_PID(&pid, TARGET_HEIGHT, current_height, dt);
        double final_angle = SERVO_DEFAULT + correction;

        // Clamp (replaces Arduino's constrain())
        if (final_angle < SERVO_MIN) final_angle = SERVO_MIN;
        if (final_angle > SERVO_MAX) final_angle = SERVO_MAX;

        servo_write((int)final_angle);

        // Serial print via USART2
        // sprintf writes a formatted string into a char buffer (like printf)
        // HAL_UART_Transmit sends raw bytes over UART
        char buf[80];
        int len = sprintf(buf,
            "Target:%.1f Current:%.2f ServoAngle:%.1f\r\n",
            TARGET_HEIGHT, current_height, final_angle);

        // HAL_UART_Transmit(handle, data_pointer, length, timeout_ms)
        HAL_UART_Transmit(&huart2, (uint8_t *)buf, len, HAL_MAX_DELAY);
    }
}
